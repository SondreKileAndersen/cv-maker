# Set this in Netlify once the ASP.NET API has been deployed.
# Example: VITE_API_BASE=https://cv-builder-api.example.com
VITE_API_BASE=

# Google OAuth client ID for direct Google Drive storage. This is safe to expose
# in the browser; do not put a client secret in any VITE_ variable.
VITE_GOOGLE_CLIENT_ID=
